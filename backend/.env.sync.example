# Copy to backend/.env.sync (gitignored) — used only by: npm run sync-db
# Pushes your local (or SOURCE_*) database into production Mongo.
#
# DEST_MONGO_URL = same value as MONGO_URL on Render (Atlas connection string).
# DEST_DB_NAME   = same as DB_NAME on Render (often test_database).

DEST_MONGO_URL=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DEST_DB_NAME=test_database

# Optional: only if your source is not localhost / backend/.env
# SOURCE_MONGO_URL=mongodb://localhost:27017
# SOURCE_DB_NAME=test_database

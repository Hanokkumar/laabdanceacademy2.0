# Copy to backend/.env (gitignored). Never commit real secrets.

# --- MongoDB ---
# Option A — RECOMMENDED (one database for local + production):
#   Use the SAME MONGO_URL and DB_NAME as Render (MongoDB Atlas).
#   Add your IP in Atlas → Network Access so local dev can connect.
#   Then CMS/admin changes from localhost are stored in production data immediately;
#   deploying only updates code, not a separate DB.
#
# Option B — Local Mongo for dev, sync before deploy:
#   MONGO_URL=mongodb://localhost:27017
#   DB_NAME=test_database
#   When you want production to match local, run: npm run sync-db
#   (requires backend/.env.sync with DEST_MONGO_URL — see .env.sync.example)

MONGO_URL=mongodb://localhost:27017
DB_NAME=test_database

# --- Auth / email (match Render in production) ---
JWT_SECRET=change_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
CORS_ORIGINS=*

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RECIPIENT_EMAIL=

# Cloudinary (same as Render for uploads)
CLOUDINARY_URL=

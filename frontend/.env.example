# Copy to `.env` for local dev, or rely on `.env.production` when running `npm run build`.
# `npm start` also loads `.env.development` (committed) so the app targets Render by default.
#
# If the Network tab still shows localhost:8000, your OS/shell may have REACT_APP_BACKEND_URL set
# (CRA will not override it from .env). Either remove that user env var, or rely on apiConfig.js
# which ignores localhost unless you opt in below.
#
# Local API (opt-in — required for http://127.0.0.1:8000 to be used):
# REACT_APP_USE_LOCAL_API=true
# REACT_APP_BACKEND_URL=http://127.0.0.1:8000
#
# Use your Render Web Service URL (Settings → URL), no trailing slash.
#
# Local backend example:
# REACT_APP_BACKEND_URL=http://127.0.0.1:8000
#
# Production (Render API):
REACT_APP_BACKEND_URL=https://laabdanceacademy2-0.onrender.com

WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false
